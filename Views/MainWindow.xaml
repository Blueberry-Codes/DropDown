<Window
    x:Class="DropDown.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:DropDown"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="DropDown - Video Downloader">

    <Grid Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBox
            x:Name="UrlTextBox"
            Grid.Row="0"
            PlaceholderText="Enter video URL"
            Header="Video URL"
            TextChanged="UrlTextBox_TextChanged"
            Margin="0,0,0,10"/>

        <TextBox
            x:Name="FileNameTextBox"
            Grid.Row="1"
            PlaceholderText="Auto-filled once a URL and instance are set"
            Header="File Name"
            TextChanged="FileNameTextBox_TextChanged"
            Margin="0,0,0,10"/>

        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel
                Grid.Column="0"
                Orientation="Horizontal"
                Spacing="8">
                <Button
                    x:Name="SelectFolderButton"
                    Content="Select Download Folder"
                    Click="SelectFolderButton_Click"/>
                <Button
                    x:Name="OpenFolderButton"
                    Content="Open Download Folder"
                    Click="OpenFolderButton_Click"
                    IsEnabled="False"/>
            </StackPanel>
            <Button
                x:Name="AboutButton"
                Grid.Column="1"
                Click="AboutButton_Click"
                Margin="0,0,8,0"
                ToolTipService.ToolTip="About DropDown">
                <FontIcon Glyph="&#xE946;" FontSize="16"/>
            </Button>
            <Button
                x:Name="HistoryButton"
                Grid.Column="2"
                Click="HistoryButton_Click"
                Margin="0,0,8,0"
                ToolTipService.ToolTip="Download History">
                <FontIcon Glyph="&#xE81C;" FontSize="16"/>
            </Button>
            <Button
                x:Name="OptionsButton"
                Grid.Column="3"
                Click="OptionsButton_Click"
                ToolTipService.ToolTip="Options: set your defaults">
                <FontIcon Glyph="&#xE713;" FontSize="16"/>
            </Button>
        </Grid>

        <TextBlock
            x:Name="SelectedFolderText"
            Grid.Row="3"
            Text="No folder selected"
            TextWrapping="Wrap"
            Margin="0,0,0,12"/>

        <StackPanel Grid.Row="4" Margin="0,0,0,12" Spacing="4">
            <StackPanel
                Orientation="Horizontal"
                Spacing="12">
                <Button
                    x:Name="SelectInstanceButton"
                    Content="Select Instance"
                    Click="SelectInstanceButton_Click"
                    VerticalAlignment="Bottom"/>
                <TextBlock
                    x:Name="SelectedInstanceText"
                    Text="No instance selected"
                    TextWrapping="Wrap"
                    VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock
                x:Name="InstanceWarningText"
                Text=""
                TextWrapping="Wrap"
                FontSize="12"
                Foreground="#E8A33D"
                Visibility="Collapsed"/>
            <HyperlinkButton
                x:Name="DonateLink"
                Padding="0"
                Visibility="Collapsed">
                <TextBlock
                    Text="💝 This instance accepts donations, click here to donate!"
                    TextWrapping="Wrap"
                    TextDecorations="Underline"
                    FontSize="12"
                    Foreground="#FF5FA8"/>
            </HyperlinkButton>
        </StackPanel>

        <ComboBox
            x:Name="DownloadModeCombo"
            Grid.Row="5"
            Header="Download Mode"
            MinWidth="160"
            SelectedIndex="0"
            SelectionChanged="DownloadModeCombo_SelectionChanged"
            Margin="0,0,0,4">
            <ComboBoxItem Content="Video" Tag="video"/>
            <ComboBoxItem Content="Audio Only" Tag="audio"/>
            <ComboBoxItem Content="Video (Muted)" Tag="mute"/>
        </ComboBox>

        <StackPanel
            Grid.Row="6"
            Orientation="Horizontal"
            Spacing="8"
            Margin="0,0,0,12">
            <ComboBox
                x:Name="VideoQualityCombo"
                Header="Video Quality"
                MinWidth="140"
                SelectedIndex="4"
                SelectionChanged="DownloadOption_Changed">
                <ComboBoxItem Content="Max" Tag="max"/>
                <ComboBoxItem Content="8K (4320p)" Tag="4320"/>
                <ComboBoxItem Content="4K (2160p)" Tag="2160"/>
                <ComboBoxItem Content="1440p (2K)" Tag="1440"/>
                <ComboBoxItem Content="1080p" Tag="1080"/>
                <ComboBoxItem Content="720p" Tag="720"/>
                <ComboBoxItem Content="480p" Tag="480"/>
                <ComboBoxItem Content="360p" Tag="360"/>
                <ComboBoxItem Content="240p" Tag="240"/>
                <ComboBoxItem Content="144p" Tag="144"/>
            </ComboBox>
            <ComboBox
                x:Name="AudioFormatCombo"
                Header="Audio Format"
                MinWidth="120"
                SelectedIndex="1"
                Visibility="Collapsed"
                SelectionChanged="DownloadOption_Changed">
                <ComboBoxItem Content="Best (original)" Tag="best"/>
                <ComboBoxItem Content=".mp3" Tag="mp3"/>
                <ComboBoxItem Content=".ogg" Tag="ogg"/>
                <ComboBoxItem Content=".opus" Tag="opus"/>
                <ComboBoxItem Content=".wav" Tag="wav"/>
            </ComboBox>
            <ComboBox
                x:Name="AudioBitrateCombo"
                Header="Bitrate"
                MinWidth="110"
                SelectedIndex="0"
                Visibility="Collapsed"
                SelectionChanged="DownloadOption_Changed">
                <ComboBoxItem Content="320 kbps" Tag="320"/>
                <ComboBoxItem Content="256 kbps" Tag="256"/>
                <ComboBoxItem Content="128 kbps" Tag="128"/>
                <ComboBoxItem Content="96 kbps" Tag="96"/>
                <ComboBoxItem Content="64 kbps" Tag="64"/>
            </ComboBox>
        </StackPanel>

        <StackPanel
            Grid.Row="7"
            VerticalAlignment="Top"
            Spacing="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button
                    x:Name="DownloadButton"
                    Grid.Column="0"
                    Content="Get"
                    Click="DownloadButton_Click"
                    HorizontalAlignment="Stretch"/>
                <Button
                    x:Name="AddToQueueButton"
                    Grid.Column="1"
                    Content="Add to Queue"
                    Click="AddToQueueButton_Click"
                    Margin="8,0,0,0"
                    ToolTipService.ToolTip="Stash this URL and keep entering more before downloading"/>
            </Grid>
            <Grid x:Name="ProgressRow" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ProgressBar
                    x:Name="DownloadProgressBar"
                    Grid.Column="0"
                    Minimum="0"
                    Maximum="100"
                    VerticalAlignment="Center"/>
                <Button
                    x:Name="CancelDownloadButton"
                    Grid.Column="1"
                    Content="Cancel"
                    Click="CancelDownloadButton_Click"
                    Margin="8,0,0,0"/>
            </Grid>
            <TextBlock
                x:Name="DownloadStatusText"
                Text=""
                TextWrapping="Wrap"
                Opacity="0.7"/>
        </StackPanel>

        <Grid
            Grid.Row="8"
            x:Name="QueuePanel"
            Visibility="Collapsed"
            Margin="0,10,0,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock
                x:Name="QueueHeader"
                Grid.Row="0"
                FontSize="13"
                Opacity="0.8"
                Margin="0,0,0,6"/>
            <ScrollViewer Grid.Row="1" MaxHeight="150" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="QueueList" Spacing="4"/>
            </ScrollViewer>
        </Grid>

        <StackPanel
            Grid.Row="9"
            x:Name="ServicesPanel"
            Visibility="Collapsed"
            Margin="0,14,0,16">
            <Button
                x:Name="ServicesToggleButton"
                Click="ServicesToggleButton_Click"
                Background="Transparent"
                BorderThickness="0"
                Padding="0"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Left">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon x:Name="ServicesChevron" Glyph="&#xE70D;" FontSize="11"/>
                    <TextBlock
                        x:Name="ServicesHeader"
                        FontSize="13"
                        Opacity="0.8"
                        TextWrapping="Wrap"/>
                </StackPanel>
            </Button>
            <ScrollViewer
                x:Name="ServicesScrollViewer"
                Visibility="Collapsed"
                VerticalScrollBarVisibility="Auto"
                Margin="0,8,0,0">
                <StackPanel x:Name="ServicesList"/>
            </ScrollViewer>
        </StackPanel>
    </Grid>
</Window>
